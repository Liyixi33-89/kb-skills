{
  "name": "kb-skills-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Turn AI Skills into an npm-installable CLI for any fullstack project (React / Vue2 / Vue3 / Node).",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "dev": "pnpm -r --parallel --filter \"./packages/*\" run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc -b",
    "clean": "pnpm -r exec rimraf dist .turbo node_modules/.cache",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "sync-skills": "tsx scripts/sync-skills.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "license": "MIT"
}